# Application
APP_NAME=barbershop
# ENVIRONMENT: "development" or "production".
# development -> /docs, /redoc, /openapi.json enabled.
# production  -> docs disabled.
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
# NOTE: use POSTGRES_HOST=localhost for local (uv) runs, and POSTGRES_HOST=db
# when running inside docker compose.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=barbershop
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cache — Redis
# Use redis://redis:6379/0 inside docker compose, localhost for local runs.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
REDIS_URL=redis://localhost:6379/0

# Message queue — RabbitMQ
# Use amqp://guest:guest@rabbitmq:5672// inside docker compose.
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Background tasks — Celery (broker: RabbitMQ, result backend: Redis)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT_SECONDS=30
