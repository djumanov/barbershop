# Application
APP_NAME=barbershop
DEBUG=false

# PostgreSQL
# NOTE: use POSTGRES_HOST=localhost for local (uv) runs, and POSTGRES_HOST=db
# when running inside docker compose.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=barbershop
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
# Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cache (config only — not yet wired to a backend)
CACHE_ENABLED=false
CACHE_BACKEND=memory
CACHE_TTL_SECONDS=300
# Only needed if CACHE_BACKEND=redis (not implemented yet)
# REDIS_URL=redis://localhost:6379/0

# Background tasks (config only — FastAPI BackgroundTasks)
BACKGROUND_TASKS_ENABLED=true
BACKGROUND_TASK_TIMEOUT_SECONDS=30
